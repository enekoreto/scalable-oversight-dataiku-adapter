# Copy this file to dataiku_pipeline/.env.metadata.local and edit as needed.
# The runner auto-fills dataset_name, model_name, and run date even if this file is not used.

# Optional explicit Dataiku dataset name override.
# If omitted, the runner uses the input CSV file name.
DATAIKU_DATASET_NAME=Summaries_added_dataset_filtered_summarized

# Optional overrides. If omitted, the runner auto-detects model and date.
# OPENLAYER_LLM_NAME=gpt-4.1-mini
# OPENLAYER_LLM_PROVIDER=azure-openai
# OPENLAYER_PROMPT_VERSION=v1
# OPENLAYER_PIPELINE_TYPE=summaries

